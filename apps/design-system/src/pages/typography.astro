---
import { typography } from "@free-fall/design-system";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Typography">
  <div class="test-container" style="padding: 2rem;">
    <h1 class="text-chapter" style="margin-bottom: 2rem;">Typography System</h1>

    <section style="margin-bottom: 4rem;">
      <h2 class="text-section" style="margin-bottom: 1rem;">
        Editorial Class Hierarchy
      </h2>
      <div
        style="display: flex; flex-direction: column; gap: 2rem; padding: 2rem; border: 1px solid var(--freefall-border-subtle); border-radius: 4px;"
      >
        <div>
          <h1
            class="text-chapter"
            style="margin-bottom: 0.5rem; margin-top: 0;"
          >
            Heading 1 / .text-chapter
          </h1>
          <div
            style="font-size: 0.75rem; color: var(--freefall-text-muted); font-family: var(--freefall-font-mono); line-height: 1.5;"
          >
            font-size: var(--freefall-type-ratio) ^ 4 *
            var(--freefall-type-base)<br />
            line-height: var(--freefall-space-1) * 10
          </div>
        </div>
        <div>
          <h2
            class="text-section"
            style="margin-bottom: 0.5rem; margin-top: 0;"
          >
            Heading 2 / .text-section
          </h2>
          <div
            style="font-size: 0.75rem; color: var(--freefall-text-muted); font-family: var(--freefall-font-mono); line-height: 1.5;"
          >
            font-size: var(--freefall-type-ratio) ^ 3 *
            var(--freefall-type-base)<br />
            line-height: var(--freefall-space-1) * 7
          </div>
        </div>
        <div>
          <h3
            class="text-subsection"
            style="margin-bottom: 0.5rem; margin-top: 0;"
          >
            Heading 3 / .text-subsection
          </h3>
          <div
            style="font-size: 0.75rem; color: var(--freefall-text-muted); font-family: var(--freefall-font-mono); line-height: 1.5;"
          >
            font-size: var(--freefall-type-ratio) ^ 2 *
            var(--freefall-type-base)<br />
            line-height: var(--freefall-space-1) * 5
          </div>
        </div>
        <div>
          <p
            class="text-body-lead"
            style="margin-bottom: 0.5rem; margin-top: 0;"
          >
            Lead Paragraph / .text-body-lead
          </p>
          <div
            style="font-size: 0.75rem; color: var(--freefall-text-muted); font-family: var(--freefall-font-mono); line-height: 1.5;"
          >
            font-size: var(--freefall-type-ratio) * var(--freefall-type-base)<br
            />
            line-height: var(--freefall-space-1) * 4
          </div>
        </div>
        <div>
          <p class="text-copy" style="margin-bottom: 0.5rem; margin-top: 0;">
            Standard Paragraph / .text-copy
          </p>
          <div
            style="font-size: 0.75rem; color: var(--freefall-text-muted); font-family: var(--freefall-font-mono); line-height: 1.5;"
          >
            font-size: var(--freefall-type-base) &rarr; 1.125rem<br />
            letter-spacing: 0.0138em (~0.25px, relative to font size)<br />
            line-height: var(--freefall-space-1) * 4
          </div>
        </div>
        <div>
          <div
            class="text-caption"
            style="margin-bottom: 0.5rem; margin-top: 0;"
          >
            Caption Text / .text-caption
          </div>
          <div
            style="font-size: 0.75rem; color: var(--freefall-text-muted); font-family: var(--freefall-font-mono); line-height: 1.5;"
          >
            font-size: var(--freefall-space-1) * 2<br />
            line-height: var(--freefall-space-1) * 2
          </div>
        </div>
        <div>
          <div class="text-ui" style="margin-bottom: 0.5rem; margin-top: 0;">
            UI Standard / .text-ui
          </div>
          <div
            style="font-size: 0.75rem; color: var(--freefall-text-muted); font-family: var(--freefall-font-mono); line-height: 1.5;"
          >
            font-size: var(--freefall-type-base) &rarr; 1.125rem<br />
            line-height: var(--freefall-space-1) * 3
          </div>
        </div>
        <div>
          <div
            class="text-ui-small"
            style="margin-bottom: 0.5rem; margin-top: 0;"
          >
            UI Small / .text-ui-small
          </div>
          <div
            style="font-size: 0.75rem; color: var(--freefall-text-muted); font-family: var(--freefall-font-mono); line-height: 1.5;"
          >
            font-size: var(--freefall-space-1) * 1.75<br />
            line-height: var(--freefall-space-1) * 3
          </div>
        </div>
      </div>
    </section>

    <section style="margin-bottom: 4rem;">
      <h2 class="text-section" style="margin-bottom: 1rem;">
        Body Text Tuning
      </h2>
      <div
        style="padding: 2rem; background: var(--freefall-bg-surface-1); border-radius: 4px;"
      >
        <p style="margin-bottom: 1rem;">
          Body text uses <code>font-size: var(--freefall-type-base)</code>
          (1.125rem) with <code>letter-spacing: 0.0138em</code> (~0.25px
          relative to font size). The tracking compensation improves legibility
          of Lato on dark backgrounds, where light-on-dark text appears
          perceptually tighter than the same tracking on light backgrounds.
        </p>
        <div
          style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;"
        >
          <div>
            <div
              class="text-ui-small"
              style="margin-bottom: 0.5rem; color: var(--freefall-text-muted);"
            >
              With tracking (default)
            </div>
            <p>
              The orbital mechanics of free-fall combat require pilots to
              maintain constant spatial awareness. Thrust vectoring in
              zero-gravity environments follows Newtonian principles — every
              action produces an equal and opposite reaction.
            </p>
          </div>
          <div>
            <div
              class="text-ui-small"
              style="margin-bottom: 0.5rem; color: var(--freefall-text-muted);"
            >
              Without tracking (comparison)
            </div>
            <p style="letter-spacing: 0;">
              The orbital mechanics of free-fall combat require pilots to
              maintain constant spatial awareness. Thrust vectoring in
              zero-gravity environments follows Newtonian principles — every
              action produces an equal and opposite reaction.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section style="margin-bottom: 4rem;">
      <h2 class="text-section" style="margin-bottom: 1rem;">
        .freefall-prose Scope Integration
      </h2>
      <div
        class="freefall-prose"
        style="padding: 2rem; background: var(--freefall-bg-surface-1); border-radius: 4px;"
      >
        <!-- Simulating markdown output -->
        <h1 id="chapter">Chapter 1: The Void</h1>
        <p>
          This is a standard paragraph showing body text within the prose scope.
          Notice how it strictly adheres to a maximum layout measure of 65
          characters to remain highly legible and comfortable to read.
        </p>

        <h2 id="section">Mechanical Systems</h2>
        <p>This represents a section heading for rules explanations.</p>

        <h3 id="subsection">Granular Rulings</h3>
        <ul>
          <li>This is a list item inside a prose scope.</li>
          <li>It should inherit proper line-height and tight indentation.</li>
        </ul>

        <blockquote>
          <p>
            Blockquotes represent flavor text or transmissions in-universe. They
            are distinct from the mechanics text to allow players to separate
            lore from rulings.
          </p>
        </blockquote>

        <table>
          <thead>
            <tr>
              <th>Attribute</th>
              <th>Base Value</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Strength</td>
              <td>10</td>
              <td>Physical power</td>
            </tr>
            <tr>
              <td>Agility</td>
              <td>14</td>
              <td>Speed and reflexes</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</BaseLayout>
