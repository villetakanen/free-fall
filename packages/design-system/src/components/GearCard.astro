---
import { Image } from "astro:assets";
import StatCircle from "./StatCircle.astro";

interface GearBase {
  title: string;
  nickname?: string;
  qualities: string[];
}

interface WeaponData extends GearBase {
  category: "weapon";
  dv: number;
  harm_type: "Physical" | "Psychic";
}

interface ArmorData extends GearBase {
  category: "armor";
  av: number;
  av_type: string;
}

interface AugmentationData extends GearBase {
  category: "augmentation";
  augmentation_category: "Spliced" | "Bionic" | "Cybernetic";
  integration: "Invasive" | "Field-Operable";
}

interface UtilityData extends GearBase {
  category: "utility";
}

interface VehicleData extends GearBase {
  category: "vehicle";
  frame: number;
  systems: number;
  pilot_binding: Binding;
  vehicle_av: number;
  size_category: "Personal" | "Small" | "Medium" | "Large" | "Huge";
}

type GearData =
  | WeaponData
  | ArmorData
  | AugmentationData
  | UtilityData
  | VehicleData;

interface Props {
  data: GearData;
  body?: number;
  mind?: number;
  ghost?: number;
  image?: ImageMetadata | string;
}

const { data, body, mind, ghost, image } = Astro.props;

const boundAttrs = [body && "body", mind && "mind", ghost && "ghost"].filter(
  Boolean,
);
const shaderStart =
  boundAttrs.length === 1
    ? `var(--freefall-attr-${boundAttrs[0]}-bg)`
    : "var(--freefall-color-primary-500)";

const categoryIcon: Record<string, string> = {
  weapon: "swords",
  armor: "shield",
  augmentation: "biotech",
  utility: "handyman",
  vehicle: "rocket_launch",
};
---

<div class="gear-card-wrap">
<article class="gear-card">
  <div class="image-zone" style={`--_shader-start: ${shaderStart}`}>
    {
      image && typeof image === "object" ? (
        <Image src={image} alt="" class="image-zone__img" />
      ) : image ? (
        <img src={image} alt="" class="image-zone__img" />
      ) : (
        <span
          class="image-zone__icon material-symbols-sharp"
          aria-hidden="true"
        >
          {categoryIcon[data.category]}
        </span>
      )
    }
    <div class="title-overlay">
      <span class="title-overlay__title text-ui">{data.title}</span>
      {
        data.nickname && (
          <span class="title-overlay__nickname text-ui-small">
            {data.nickname}
          </span>
        )
      }
    </div>
  </div>

  <div class="stats-zone">
    {
      data.category === "weapon" && (
        <div class="category-stats text-ui-small">
          <span>DV {data.dv}</span>
          <span class="category-stats__sep">&middot;</span>
          <span>{data.harm_type}</span>
        </div>
      )
    }
    {
      data.category === "armor" && (
        <div class="category-stats text-ui-small">
          <span>AV {data.av}</span>
          <span class="category-stats__sep">&middot;</span>
          <span>{data.av_type}</span>
        </div>
      )
    }
    {
      data.category === "augmentation" && (
        <div class="category-stats text-ui-small">
          <span>{data.augmentation_category}</span>
          <span class="category-stats__sep">&middot;</span>
          <span>{data.integration}</span>
        </div>
      )
    }
    {
      data.category === "vehicle" && (
        <div class="category-stats text-ui-small">
          <span>Frame {data.frame}</span>
          <span class="category-stats__sep">&middot;</span>
          <span>Sys {data.systems}</span>
          <span class="category-stats__sep">&middot;</span>
          <span>AV {data.vehicle_av}</span>
          <span class="category-stats__sep">&middot;</span>
          <span>{data.size_category}</span>
        </div>
      )
    }

    {
      data.qualities.length > 0 && (
        <ul class="qualities">
          {data.qualities.map((q) => (
            <li class="qualities__item text-ui-small">{q}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>
<div class="binding-row">
  <StatCircle type="body" attribute="Body" value={body || null} />
  <StatCircle type="mind" attribute="Mind" value={mind || null} />
  <StatCircle type="ghost" attribute="Ghost" value={ghost || null} />
</div>
</div>

<style>
  .gear-card {
    width: calc(32 * var(--freefall-space-1));
    height: calc(44.5 * var(--freefall-space-1));
    border-radius: calc(2 * var(--freefall-space-1));
    background: var(--freefall-bg-surface-1);
    border: calc(var(--freefall-space-1) / 4) solid
      var(--freefall-border-strong);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* ── Image zone ─────────────────────────────── */

  .image-zone {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    flex-shrink: 0;
    background: var(--freefall-bg-surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .image-zone::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      140deg,
      oklch(from var(--_shader-start) l c h / 0.55),
      oklch(from var(--freefall-color-primary-900) l c h / 0.75)
    );
    pointer-events: none;
    z-index: 0;
  }

  .image-zone__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-zone__icon {
    font-size: calc(10 * var(--freefall-space-1));
    color: var(--freefall-color-primary-600);
    line-height: 1;
    z-index: 1;
  }

  /* ── Binding cost circles ───────────────────── */

  .gear-card-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .binding-row {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: calc(1.5 * var(--freefall-space-1));
    transform: translateY(50%);
    z-index: 1;
  }

  /* ── Title overlay ────────────────────────────── */

  .title-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: calc(1.5 * var(--freefall-space-1))
      calc(2 * var(--freefall-space-1));
    display: flex;
    flex-direction: column;
    gap: calc(0.25 * var(--freefall-space-1));
    z-index: 1;
  }

  .title-overlay__title {
    font-weight: 700;
    color: var(--freefall-color-primary-50);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-shadow: var(--freefall-text-shadow-overlay);
  }

  .title-overlay__nickname {
    color: var(--freefall-color-primary-50);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0.85;
    text-shadow: var(--freefall-text-shadow-overlay);
  }

  /* ── Stats zone ─────────────────────────────── */

  .stats-zone {
    flex: 1;
    padding: calc(1.5 * var(--freefall-space-1))
      calc(2 * var(--freefall-space-1));
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: calc(1 * var(--freefall-space-1));
  }

  .category-stats {
    display: flex;
    flex-wrap: wrap;
    gap: calc(0.5 * var(--freefall-space-1));
    color: var(--freefall-text-high);
    font-weight: 600;
  }

  .category-stats__sep {
    color: var(--freefall-text-muted);
  }

  .qualities {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: calc(0.5 * var(--freefall-space-1));
  }

  .qualities__item {
    color: var(--freefall-text-body);
    padding-left: calc(2 * var(--freefall-space-1));
    position: relative;
  }

  .qualities__item::before {
    content: "●";
    position: absolute;
    left: 0;
    color: var(--freefall-text-muted);
    font-size: calc(1 * var(--freefall-space-1));
    top: calc(0.25 * var(--freefall-space-1));
  }
</style>
