---
interface Props {
  icon: string;
  label: string;
  href: string;
  active?: boolean;
}

const { icon, label, href, active } = Astro.props;
---

<a
  class="tray-button text-ui"
  href={href}
  aria-current={active ? "page" : undefined}
>
  <span class="icon material-symbols-sharp" aria-hidden="true">
    {icon}
  </span>
  <span class="label">{label}</span>
</a>

<style>
  .tray-button {
    display: flex;
    align-items: center;
    gap: calc(2 * var(--freefall-space-1));
    padding: calc(2 * var(--freefall-space-1));
    height: calc(var(--freefall-space-1) * 6);
    color: var(--freefall-text-display);
    text-decoration: none;
    cursor: pointer;
    border-radius: 9999px;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;

    --tray-button-icon-size: calc(3 * var(--freefall-space-1));
  }

  .icon {
    font-size: var(--tray-button-icon-size);
    flex-shrink: 0;
    line-height: 1;
  }

  .label {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tray-button:hover {
    background: var(--freefall-action-hover);
  }

  .tray-button:focus-visible {
    outline: calc(var(--freefall-space-1) / 4) solid var(--freefall-alert-base);
    outline-offset: calc(var(--freefall-space-1) / 4);
  }

  .tray-button[aria-current="page"] {
    color: var(--freefall-text-display);
    background: var(--freefall-bg-surface-2);
  }

  .tray-button[aria-current="page"] .icon {
    font-variation-settings: "FILL" 1;
  }

  @container (max-width: 64px) {
    .tray-button {
      width: calc(6 * var(--freefall-space-1));
      justify-content: center;
      margin-inline: auto;
      gap: 0;
    }

    .label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
</style>
