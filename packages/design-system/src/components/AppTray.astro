---
import DrawerBrand from "./DrawerBrand.astro";
import HamburgerButton from "./HamburgerButton.astro";
import TrayButton from "./TrayButton.astro";
import TrayLink from "./TrayLink.astro";
import TrayLinkGroup from "./TrayLinkGroup.astro";

/**
 * app-tray-drawer
 *
 * Owns HamburgerButton in the AppShell - as HamburgerButton should
 * never be rendered in the AppShell, unless the Tray exists in the dom.
 */

interface NavItem {
  icon: string;
  label: string;
  href: string;
  active?: boolean;
  subItems?: {
    label: string;
    href: string;
    active?: boolean;
  }[];
}

interface Props {
  items: NavItem[];
  brandHref?: string;
}

const { items, brandHref } = Astro.props;
---

<div class="app-tray">
  <HamburgerButton id="app-tray-toggle" />

  <div class="drawer">
    <nav id="app-tray-nav" class="nav" aria-label="Main navigation">
      {
        items.map((item: NavItem) => (
          <>
            <TrayButton
              icon={item.icon}
              label={item.label}
              href={item.href}
              active={item.active}
            />
            {item.subItems && (
              <TrayLinkGroup>
                {item.subItems.map((subItem) => (
                  <TrayLink
                    href={subItem.href}
                    label={subItem.label}
                    active={subItem.active}
                  />
                ))}
              </TrayLinkGroup>
            )}
          </>
        ))
      }
    </nav>
    <DrawerBrand href={brandHref} />
  </div>

  <label
    for="app-tray-toggle"
    class="scrim"
    aria-label="Close navigation"></label>
</div>

<style>
  /* ── Tokens ─────────────────────────────────────────── */
  .app-tray {
    --app-tray-z-tray: 100;
    --app-tray-z-scrim: 99;
    --app-tray-rail-width: calc(10 * var(--freefall-space-1));
    --app-tray-tray-width: calc(40 * var(--freefall-space-1));
    --app-tray-burger-size: calc(6 * var(--freefall-space-1));
    --app-tray-icon-size: calc(3 * var(--freefall-space-1));

    display: flex;
    flex-direction: row;
    position: relative;
    top: 0;
    left: 0;
    height: 100%;
    background: var(--freefall-bg-surface-1);
    width: 0;
  }
  .app-tray:has(#app-tray-toggle:checked) {
    width: 0;
  }

  /* ── Hamburger (child component, needs :global) ───── */
  .app-tray > :global(.hamburger-btn) {
    position: fixed;
    top: var(--freefall-space-2);
    left: var(--freefall-space-2);
    z-index: calc(var(--app-tray-z-tray) + 2);
  }

  /* ── Drawer column ─────────────────────────────────── */
  .drawer {
    position: fixed;
    top: 0;
    left: 0;
    z-index: var(--app-tray-z-tray);
    display: flex;
    flex-direction: column;
    height: 100%;
    width: var(--app-tray-tray-width);
    max-width: 100vw;
    background: var(--freefall-bg-surface-1);
    transform: translateX(-100%);
    transition:
      transform 150ms ease-in,
      width 150ms ease-in;
    border-right: none;
    container-type: inline-size;
    padding-top: calc(
      var(--app-tray-burger-size) + 2 * var(--freefall-space-2)
    );
    padding-bottom: var(--freefall-space-2);
    padding-left: calc(var(--freefall-space-1) * 1.5);
    padding-right: calc(var(--freefall-space-1) * 1.5);
  }

  .app-tray:has(#app-tray-toggle:checked) .drawer {
    transform: translateX(0);
    transition:
      transform 200ms ease-out,
      width 200ms ease-out;
  }

  /* ── Nav (scrollable region) ───────────────────────── */
  .nav {
    display: flex;
    flex-direction: column;
    gap: var(--freefall-space-1);
    align-items: flex-start;
    flex: 1;
    overflow-y: auto;
  }

  /* ── Scrim ─────────────────────────────────────────── */
  .scrim {
    display: none;
    position: fixed;
    inset: 0;
    z-index: var(--app-tray-z-scrim);
    background: var(--freefall-bg-canvas);
    opacity: 0;
    transition: opacity 150ms ease-in;
    cursor: pointer;
  }
  .app-tray:has(#app-tray-toggle:checked) .scrim {
    display: block;
    opacity: 0.6;
    transition: opacity 200ms ease-out;
  }

  /* ── Tablet: rail + overlay tray ───────────────────── */
  @media (min-width: 621px) {
    .app-tray {
      width: var(--app-tray-rail-width);
      transition: 270ms width;
    }
    .app-tray:has(#app-tray-toggle:checked) {
      width: var(--app-tray-tray-width);
    }

    .drawer {
      position: relative;
      transform: translateX(0);
      width: var(--app-tray-rail-width);
      flex-shrink: 0;
      border-right: calc(var(--freefall-space-1) / 4) solid
        var(--freefall-border-subtle);
      z-index: calc(var(--app-tray-z-tray) + 1);
    }
    .app-tray:has(#app-tray-toggle:checked) .drawer {
      position: absolute;
      height: 100vh;
      width: var(--app-tray-tray-width);
    }
  }

  /* ── Desktop: rail + push tray ─────────────────────── */
  @media (min-width: 780px) {
    .app-tray:has(#app-tray-toggle:checked) .scrim {
      display: none;
    }
    .app-tray:has(#app-tray-toggle:checked) .drawer {
      position: relative;
      width: var(--app-tray-tray-width);
    }
  }
</style>

<script>
  const toggle = document.getElementById(
    "app-tray-toggle",
  ) as HTMLInputElement | null;
  const drawer = document.getElementById("app-tray-nav");

  if (toggle && drawer) {
    const isOverlay = () => !window.matchMedia("(min-width: 780px)").matches;

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.checked) {
        toggle.checked = false;
      }

      if (e.key === "Tab" && toggle.checked && isOverlay()) {
        const focusable = drawer.querySelectorAll<HTMLElement>(
          'a, button, [tabindex]:not([tabindex="-1"])',
        );
        if (focusable.length === 0) return;

        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }
</script>
