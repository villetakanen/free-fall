---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="app-bar">
  <span class="title">{title}</span>
  <div class="actions">
    <slot />
  </div>
</header>

<style>
  .app-bar {
    display: flex;
    flex-direction: row;
    align-items: center;
    flex-shrink: 0;
    height: calc(8 * var(--freefall-space-1));
    margin-left: calc(8 * var(--freefall-space-1));
    padding: 0 var(--freefall-space-2);
    background: transparent;
  }

  @media (min-width: 620px) {
    .app-bar {
      margin-left: 0;
      padding: 0 var(--freefall-space-4);
    }
  }

  .title {
    color: var(--freefall-text-display);
    font-size: calc(var(--freefall-type-ratio) * 2 * var(--freefall-space-1));
  }

  .actions {
    display: flex;
    flex-direction: row;
    align-items: center;
    flex-wrap: nowrap;
    gap: var(--freefall-space-1);
    margin-left: auto;
  }
</style>
