---
import AppBar from "./AppBar.astro";
import AppTray from "./AppTray.astro";
import FontLinks from "./FontLinks.astro";
import "../styles/base.css";

interface NavItem {
  icon: string;
  label: string;
  href: string;
  active?: boolean;
  subItems?: {
    label: string;
    href: string;
    active?: boolean;
  }[];
}

interface Props {
  title: string;
  navItems: NavItem[];
  brandHref?: string;
}

const { title, navItems, brandHref } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <FontLinks />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <div class="app-shell">
      <AppTray items={navItems} brandHref={brandHref} />
      <div class="app">
        <AppBar title={title} />
        <main>
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  /*
 * This style is scoped to app-shell only, it's not used elswhere in the app
 */
  .app-shell {
    display: flex;
    flex-direction: row;
    height: 100dvh;
    width: 100dvw;
    overflow: hidden;
  }
  .app-shell > .app {
    flex-grow: 1;
    width: 100%;
    height: 100%;
  }
  .app-shell main {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    container-type: inline-size;
    container-name: content;
    padding-bottom: 200px;
  }
</style>
