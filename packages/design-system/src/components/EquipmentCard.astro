---
interface Binding {
  body: number;
  mind: number;
  ghost: number;
}

interface GearBase {
  title: string;
  nickname?: string;
  binding: Binding;
  qualities: string[];
}

interface WeaponData extends GearBase {
  category: "weapon";
  dv: number;
  harm_type: "Physical" | "Psychic";
}

interface ArmorData extends GearBase {
  category: "armor";
  av: number;
  av_type: string;
}

interface AugmentationData extends GearBase {
  category: "augmentation";
  augmentation_category: "Spliced" | "Bionic" | "Cybernetic";
  integration: "Invasive" | "Field-Operable";
}

interface UtilityData extends GearBase {
  category: "utility";
}

interface VehicleData extends GearBase {
  category: "vehicle";
  frame: number;
  systems: number;
  pilot_binding: Binding;
  vehicle_av: number;
  size_category: "Personal" | "Small" | "Medium" | "Large" | "Huge";
}

type GearData =
  | WeaponData
  | ArmorData
  | AugmentationData
  | UtilityData
  | VehicleData;

interface Props {
  data: GearData;
  image?: string;
}

const { data, image } = Astro.props;

const bindingEntries = [
  {
    key: "body",
    label: "B",
    value: data.binding.body,
    className: "binding--body",
  },
  {
    key: "mind",
    label: "M",
    value: data.binding.mind,
    className: "binding--mind",
  },
  {
    key: "ghost",
    label: "G",
    value: data.binding.ghost,
    className: "binding--ghost",
  },
];

const categoryIcon: Record<string, string> = {
  weapon: "swords",
  armor: "shield",
  augmentation: "biotech",
  utility: "handyman",
  vehicle: "rocket_launch",
};
---

<article class="equipment-card">
  <div class="image-zone">
    {image ? (
      <img src={image} alt="" class="image-zone__img" />
    ) : (
      <span class="image-zone__icon material-symbols-sharp" aria-hidden="true">
        {categoryIcon[data.category]}
      </span>
    )}
    <div class="title-overlay">
      <span class="title-overlay__title text-ui">{data.title}</span>
      {data.nickname && (
        <span class="title-overlay__nickname text-ui-small">{data.nickname}</span>
      )}
    </div>
    <div class="binding-row">
      {bindingEntries.map((entry) => (
        <span
          class={`binding-circle ${entry.className} ${entry.value === 0 ? "binding--empty" : ""}`}
          title={entry.key}
        >
          <span class="binding-circle__value">
            {entry.value > 0 ? entry.value : ""}
          </span>
          <span class="binding-circle__label">{entry.label}</span>
        </span>
      ))}
    </div>
  </div>

  <div class="stats-zone">
    {data.category === "weapon" && (
      <div class="category-stats text-ui-small">
        <span>DV {data.dv}</span>
        <span class="category-stats__sep">&middot;</span>
        <span>{data.harm_type}</span>
      </div>
    )}
    {data.category === "armor" && (
      <div class="category-stats text-ui-small">
        <span>AV {data.av}</span>
        <span class="category-stats__sep">&middot;</span>
        <span>{data.av_type}</span>
      </div>
    )}
    {data.category === "augmentation" && (
      <div class="category-stats text-ui-small">
        <span>{data.augmentation_category}</span>
        <span class="category-stats__sep">&middot;</span>
        <span>{data.integration}</span>
      </div>
    )}
    {data.category === "vehicle" && (
      <div class="category-stats text-ui-small">
        <span>Frame {data.frame}</span>
        <span class="category-stats__sep">&middot;</span>
        <span>Sys {data.systems}</span>
        <span class="category-stats__sep">&middot;</span>
        <span>AV {data.vehicle_av}</span>
        <span class="category-stats__sep">&middot;</span>
        <span>{data.size_category}</span>
      </div>
    )}

    {data.qualities.length > 0 && (
      <ul class="qualities">
        {data.qualities.map((q) => (
          <li class="qualities__item text-ui-small">{q}</li>
        ))}
      </ul>
    )}
  </div>
</article>

<style>
  .equipment-card {
    width: calc(32 * var(--freefall-space-1));
    height: calc(44.5 * var(--freefall-space-1));
    border-radius: calc(2 * var(--freefall-space-1));
    background: var(--freefall-bg-surface-1);
    border: calc(var(--freefall-space-1) / 4) solid var(--freefall-border-strong);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* ── Image zone ─────────────────────────────── */

  .image-zone {
    position: relative;
    height: 45%;
    background: var(--freefall-bg-surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .image-zone__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-zone__icon {
    font-size: calc(10 * var(--freefall-space-1));
    color: var(--freefall-color-primary-600);
    line-height: 1;
  }

  /* ── Binding cost circles ───────────────────── */

  .binding-row {
    position: absolute;
    bottom: calc(1 * var(--freefall-space-1));
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: calc(1.5 * var(--freefall-space-1));
  }

  .binding-circle {
    width: calc(5 * var(--freefall-space-1));
    height: calc(5 * var(--freefall-space-1));
    border-radius: 9999px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    line-height: 1;
    border: calc(var(--freefall-space-1) / 4) solid
      color-mix(in srgb, transparent, white 20%);
  }

  .binding-circle__value {
    font-size: calc(2 * var(--freefall-space-1));
    font-weight: 700;
  }

  .binding-circle__label {
    font-size: calc(1.25 * var(--freefall-space-1));
    text-transform: uppercase;
    opacity: 0.8;
  }

  .binding--empty {
    opacity: 0.35;
  }

  .binding--body {
    background: var(--freefall-attr-body);
    color: var(--freefall-color-primary-950);
  }

  .binding--mind {
    background: var(--freefall-attr-mind);
    color: var(--freefall-color-primary-950);
  }

  .binding--ghost {
    background: var(--freefall-attr-ghost);
    color: var(--freefall-color-primary-950);
  }

  /* ── Title overlay ────────────────────────────── */

  .title-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: calc(1.5 * var(--freefall-space-1)) calc(2 * var(--freefall-space-1));
    display: flex;
    flex-direction: column;
    gap: calc(0.25 * var(--freefall-space-1));
    z-index: 1;
  }

  .title-overlay__title {
    font-weight: 700;
    color: var(--freefall-color-primary-50);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-shadow:
      0 2px 4px rgba(0, 0, 0, 0.6),
      0 4px 8px rgba(0, 0, 0, 0.4),
      0 8px 16px rgba(0, 0, 0, 0.2);
  }

  .title-overlay__nickname {
    color: var(--freefall-color-primary-50);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0.85;
    text-shadow:
      0 2px 4px rgba(0, 0, 0, 0.6),
      0 4px 8px rgba(0, 0, 0, 0.4),
      0 8px 16px rgba(0, 0, 0, 0.2);
  }

  /* ── Stats zone ─────────────────────────────── */

  .stats-zone {
    flex: 1;
    padding: calc(1.5 * var(--freefall-space-1)) calc(2 * var(--freefall-space-1));
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: calc(1 * var(--freefall-space-1));
  }

  .category-stats {
    display: flex;
    flex-wrap: wrap;
    gap: calc(0.5 * var(--freefall-space-1));
    color: var(--freefall-text-high);
    font-weight: 600;
  }

  .category-stats__sep {
    color: var(--freefall-text-muted);
  }

  .qualities {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: calc(0.5 * var(--freefall-space-1));
  }

  .qualities__item {
    color: var(--freefall-text-body);
    padding-left: calc(2 * var(--freefall-space-1));
    position: relative;
  }

  .qualities__item::before {
    content: "●";
    position: absolute;
    left: 0;
    color: var(--freefall-text-muted);
    font-size: calc(1 * var(--freefall-space-1));
    top: calc(0.25 * var(--freefall-space-1));
  }
</style>
